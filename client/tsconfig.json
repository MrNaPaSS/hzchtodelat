{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "shared": ["../shared/src"]
    },
    "noEmit": true
  },
  "include": ["src/**/*", "../shared/src/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
