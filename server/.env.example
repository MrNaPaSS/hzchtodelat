# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/durak_online?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Telegram Bot
BOT_TOKEN="your_bot_token_here"

# JWT
JWT_SECRET="your_jwt_secret_here_change_in_production"
JWT_EXPIRES_IN="7d"

# Game
COMMISSION_RATE=0.05
NMNH_EXCHANGE_RATE=100
MIN_EXCHANGE_NMNH=500
MAX_DAILY_WITHDRAWAL_STARS=1000
EXCHANGE_COOLDOWN_HOURS=24

# Client URL (CORS)
CLIENT_URL="http://localhost:5173"
